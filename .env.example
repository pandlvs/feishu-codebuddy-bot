# 飞书远程MCP服务器URL（StreamableHTTP）
FEISHU_MCP_URL=https://open.feishu.cn/mcp/stream/your_token_here

# Claude API 配置
CLAUDE_API_KEY=sk-ant-xxx
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_ROUTER_MODEL=claude-haiku-4-5-20251001
CLAUDE_QA_MODEL=claude-sonnet-4-6

# Router 引擎选择：claude 或 codebuddy（默认 claude）
# claude: 使用 Claude API 做意图分类（需要 CLAUDE_API_KEY）
# codebuddy: 使用 CodeBuddy SDK 做意图分类（需要 CodeBuddy 登录）
ROUTER_ENGINE=claude

# QA 引擎配置（可分别配置 product-qa 和 general-qa）
# 可选值：claude 或 codebuddy（默认 claude）
# QA_ENGINE: 全局默认引擎，未单独配置时使用
# PRODUCT_QA_ENGINE: product-qa 专用引擎（优先级高于 QA_ENGINE）
# GENERAL_QA_ENGINE: general-qa 专用引擎（优先级高于 QA_ENGINE）
QA_ENGINE=claude
# PRODUCT_QA_ENGINE=codebuddy
# GENERAL_QA_ENGINE=claude

# CodeBuddy配置
WORKING_DIR=/path/to/your/code
DEFAULT_PERMISSION_MODE=acceptEdits
DEFAULT_MAX_TURNS=10

# 知识库和会话存储
KNOWLEDGE_DIR=./knowledge
SESSIONS_DIR=./sessions

# 轮询间隔（毫秒）
POLL_INTERVAL=5000

# 监听的群聊 ID 列表，逗号分隔（必填）
WATCH_CHAT_IDS=oc_xxxxxxxx,oc_yyyyyyyy

# 只响应这些用户发送的消息，逗号分隔（留空则响应所有人）
ALLOWED_SENDER_IDS=ou_xxxxxxxx,ou_yyyyyyyy

# 机器人自身的 open_id（individual 模式必填，用于识别 @机器人）
BOT_OPEN_ID=ou_xxxxxxxx

# 默认群聊模式：individual（独立会话，@机器人触发）或 shared（共享会话，所有消息）
DEFAULT_CHAT_MODE=individual

# 单独指定某个群的模式，覆盖默认值
# CHAT_MODE_oc_xxxxxxxx=shared
# CHAT_MODE_oc_yyyyyyyy=individual

# 群能力配置：指定某个群支持哪些意图，逗号分隔（不配置则支持所有）
# CHAT_CAPABILITIES_oc_xxxxxxxx=ngs-product-qa,ngs-bug-fixer
# CHAT_CAPABILITIES_oc_yyyyyyyy=ngs-bug-fixer

# 群默认意图（内网环境下 Router 失败时使用，或直接跳过 Router）
# 可选值：ngs-product-qa, ngs-bug-fixer, general-qa
# CHAT_DEFAULT_INTENT_oc_xxxxxxxx=ngs-bug-fixer
# CHAT_DEFAULT_INTENT_oc_yyyyyyyy=general-qa

# 超出能力范围时的回复
OUT_OF_SCOPE_REPLY=抱歉，暂时还不支持，可以尝试把问题创建成飞书任务。
